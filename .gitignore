# -----------------------------
# Generated analysis outputs
# -----------------------------

# Ignore ALL results outputs by default
projects/*/results/**
projects/clinical-trial-statistical-analysis/**/projects/*/results/**

# Re-include results/ folders so exceptions below can apply
!projects/*/results/
!projects/clinical-trial-statistical-analysis/**/projects/*/results/

# Keep results README files
!projects/*/results/README.md
!projects/*/results/README.MD
!projects/*/results/README.txt
!projects/*/results/README.Rmd

!projects/clinical-trial-statistical-analysis/**/projects/*/results/README.md
!projects/clinical-trial-statistical-analysis/**/projects/*/results/README.MD
!projects/clinical-trial-statistical-analysis/**/projects/*/results/README.txt
